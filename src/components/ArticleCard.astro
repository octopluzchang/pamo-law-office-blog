---
interface Props {
  title: string;
  href: string;
  image?: string;
  categoryLabel?: string;
  categorySlug?: string;
}

const {
  title,
  href,
  image,
  categoryLabel,
  categorySlug
} = Astro.props;

const coverImage = image ?? '/assets/default_cover.png';
---

<article class="article-card">
  <a href={href} class="block">
    <div class="aspect-4/3 bg-[#2e2e2e] relative overflow-hidden">
      <img
        src="/assets/hero_bg.svg"
        alt=""
        class="absolute inset-0 w-full h-full object-cover opacity-40"
      />
      <img
        src={coverImage}
        alt={title}
        class="relative z-10 h-full w-full object-cover"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    </div>

    <div class="min-h-24.5 px-6 py-5 md:min-h-27.5 flex flex-col items-center justify-center text-center">
      {categoryLabel && categorySlug && (
        <div class="mb-3">
          <a
            href={`/articles/category/${categorySlug}/`}
            class="inline-block px-3 py-1 text-xs font-bold rounded-full border border-[#c69c7b] text-[#c69c7b] hover:bg-[#c69c7b] hover:text-white transition"
          >
            {categoryLabel}
          </a>
        </div>
      )}

      <div class="min-h-14.5 flex items-center">
        <h5 class="article-card-title">{title}</h5>
      </div>
    </div>
  </a>
</article>