---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="民間借貸合理結清試算｜略策法律事務所"
  description="30 秒看出金主要求你結清的金額，法律上合不合理。"
>
  <style is:global>

.loan-calculator *, .loan-calculator *::before, .loan-calculator *::after { box-sizing: border-box; margin: 0; padding: 0; }
.loan-calculator {
  --brand: #d3a07c; --brand-d: #a87249; --ink: #111111; --sub: #6f6f6f;
  --line: #e5d8cf; --bg: #f7f4f1; --card: #fff;
  --green: #16a34a; --green-bg: #f0fdf4; --green-bd: #86efac;
  --yellow: #d97706; --yellow-bg: #fffbeb; --yellow-bd: #fcd34d;
  --red: #dc2626; --red-bg: #fef2f2; --red-bd: #fca5a5;
}
.loan-calculator { font-family: 'Noto Sans TC', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--ink); line-height: 1.5; min-height: 100vh; padding-top: 92px; }
.loan-calculator .wrap { max-width: 460px; margin: 0 auto; min-height: calc(100vh - 92px); background: var(--bg); display: flex; flex-direction: column; }

/* Header */
.top { background: #111; color: #fff; padding: 24px 20px 20px; border-bottom: 4px solid var(--brand); }
.top h1 { font-size: 19px; font-weight: 800; letter-spacing: .01em; }
.top p { font-size: 13px; opacity: .92; margin-top: 4px; }

/* Progress dots */
.dots { display: flex; gap: 6px; padding: 14px 20px 0; }
.dot { flex: 1; height: 4px; border-radius: 3px; background: var(--line); transition: background .3s; }
.dot.on { background: var(--brand); }

.scroll { flex: 1; padding: 16px 18px 28px; }

/* Step card */
.step { display: none; }
.step.active { display: block; animation: fade .25s ease; }
@keyframes fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

.q { font-size: 18px; font-weight: 800; margin-bottom: 4px; }
.q .num { color: var(--brand); margin-right: 6px; }
.q-sub { font-size: 13px; color: var(--sub); margin-bottom: 16px; }

.field { margin-bottom: 18px; }
.lbl { font-size: 14px; font-weight: 700; margin-bottom: 8px; display: block; }
.lbl .opt { font-weight: 400; color: var(--sub); font-size: 12px; margin-left: 4px; }

/* number input */
.ni { display: flex; align-items: center; border: 2px solid var(--line); border-radius: 12px; background: #fff; overflow: hidden; transition: border-color .15s; }
.ni:focus-within { border-color: var(--brand); }
.ni input { flex: 1; min-width: 0; border: none; outline: none; padding: 14px 14px; font-size: 18px; font-weight: 700; font-family: inherit; color: var(--ink); background: transparent; }
.ni input::placeholder { color: #cbd5e1; font-weight: 400; }
.ni .u { padding: 0 14px; font-size: 14px; color: var(--sub); font-weight: 600; background: #f8fafc; align-self: stretch; display: flex; align-items: center; border-left: 1px solid var(--line); }

/* quick buttons */
.chips { display: flex; flex-wrap: wrap; gap: 8px; }
.chip { border: 2px solid var(--line); background: #fff; border-radius: 10px; padding: 11px 16px; font-size: 15px; font-weight: 700; color: #334155; cursor: pointer; font-family: inherit; transition: all .12s; }
.chip:active { transform: scale(.97); }
.chip.sel { border-color: var(--brand); background: #fff8f3; color: var(--brand-d); }

.hintline { font-size: 12px; color: var(--sub); margin-top: 7px; line-height: 1.5; }

/* nav */
.nav { display: flex; gap: 10px; margin-top: 8px; }
.btn { padding: 15px; border-radius: 13px; font-size: 16px; font-weight: 800; font-family: inherit; cursor: pointer; border: none; transition: transform .1s; }
.btn:active { transform: scale(.98); }
.btn-go { flex: 1; background: var(--brand); color: #111; box-shadow: 0 6px 16px rgba(211,160,124,.3); }
.btn-back { background: #fff; color: var(--sub); border: 2px solid var(--line); padding: 15px 18px; }
.btn-go:disabled { background: #cbd5e1; box-shadow: none; cursor: not-allowed; }

/* ───── RESULT ───── */
.result-card { border-radius: 18px; padding: 24px 20px; text-align: center; margin-bottom: 16px; border: 2px solid; }
.result-card.green { background: var(--green-bg); border-color: var(--green-bd); }
.result-card.yellow { background: var(--yellow-bg); border-color: var(--yellow-bd); }
.result-card.red { background: var(--red-bg); border-color: var(--red-bd); }
.r-emoji { font-size: 44px; line-height: 1; margin-bottom: 10px; }
.r-badge { display: inline-block; font-size: 13px; font-weight: 800; padding: 5px 14px; border-radius: 20px; color: #fff; margin-bottom: 12px; }
.green .r-badge { background: var(--green); }
.yellow .r-badge { background: var(--yellow); }
.red .r-badge { background: var(--red); }
.r-title { font-size: 21px; font-weight: 900; margin-bottom: 8px; }
.green .r-title { color: var(--green); }
.yellow .r-title { color: var(--yellow); }
.red .r-title { color: var(--red); }
.r-desc { font-size: 14px; color: #334155; line-height: 1.7; }

/* legend */
.legend { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 14px 16px; margin-bottom: 16px; }
.legend-t { font-size: 12px; font-weight: 800; color: var(--sub); letter-spacing: .04em; margin-bottom: 10px; }
.leg-row { display: flex; gap: 10px; align-items: flex-start; padding: 7px 0; font-size: 12.5px; color: #475569; line-height: 1.5; }
.leg-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; margin-top: 3px; }
.leg-dot.g { background: var(--green); } .leg-dot.y { background: var(--yellow); } .leg-dot.r { background: var(--red); }
.leg-row b { color: var(--ink); }

/* CTA / lead */
.cta-card { background: #111; color: #fff; border-radius: 18px; padding: 22px 20px; border: 1px solid #2b2b2b; }
.cta-card h2 { font-size: 18px; font-weight: 800; margin-bottom: 6px; }
.cta-card p { font-size: 13.5px; opacity: .94; line-height: 1.7; margin-bottom: 16px; }
.lead-field { margin-bottom: 12px; }
.lead-field input { width: 100%; border: none; border-radius: 11px; padding: 14px; font-size: 16px; font-family: inherit; color: var(--ink); }
.lead-field input:focus { outline: 3px solid rgba(255,255,255,.35); }
.btn-consult { width: 100%; background: var(--brand); color: #111; padding: 16px; border-radius: 13px; font-size: 17px; font-weight: 900; border: none; font-family: inherit; cursor: pointer; margin-top: 4px; }
.btn-consult:active { transform: scale(.98); }
.btn-consult:disabled { background: rgba(255,255,255,.4); color: rgba(255,255,255,.7); cursor: not-allowed; }
.cta-fine { font-size: 11px; opacity: .8; margin-top: 12px; line-height: 1.5; text-align: center; }

.thanks { text-align: center; padding: 30px 20px; }
.thanks .big { font-size: 50px; margin-bottom: 12px; }
.thanks h2 { font-size: 20px; font-weight: 800; color: var(--brand-d); margin-bottom: 8px; }
.thanks p { font-size: 14px; color: var(--sub); line-height: 1.7; }
.thanks a { display: inline-block; margin-top: 18px; background: #06c755; color: #fff; padding: 14px 28px; border-radius: 13px; font-weight: 800; text-decoration: none; font-size: 16px; }

.disclaimer { font-size: 11px; color: #94a3b8; line-height: 1.6; padding: 18px; text-align: center; }
.restart { text-align: center; margin-top: 14px; }
.restart button { background: none; border: none; color: var(--sub); font-size: 13px; text-decoration: underline; cursor: pointer; font-family: inherit; }

@media (max-width: 720px) { .loan-calculator { padding-top: 82px; } .loan-calculator .wrap { min-height: calc(100vh - 82px); } }

  </style>

  <main class="loan-calculator">
<div class="wrap">

  <div class="top">
    <h1>我現在合理該還多少？</h1>
    <p>30 秒看出金主要求你結清的金額，法律上合不合理</p>
  </div>

  <div class="dots" id="dots">
    <div class="dot on"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div>
  </div>

  <div class="scroll">

    <!-- STEP 1 -->
    <div class="step active" id="s1">
      <div class="q"><span class="num">1</span>金主現在要你拿多少錢結清？</div>
      <div class="q-sub">就是對方開口要你一次還清的金額。</div>
      <div class="field">
        <div class="ni"><input id="settle" inputmode="numeric" placeholder="例：6,000,000" oninput="fmt(this);chk()"><span class="u">元</span></div>
      </div>
      <div class="nav"><button class="btn btn-go" id="g1" onclick="go(2)" disabled>下一步</button></div>
    </div>

    <!-- STEP 2 -->
    <div class="step" id="s2">
      <div class="q"><span class="num">2</span>你的借款狀況</div>
      <div class="q-sub">當初的條件與目前繳到哪。</div>

      <div class="field">
        <label class="lbl">當初借了多少（本金）</label>
        <div class="ni"><input id="prin" inputmode="numeric" placeholder="例：3,000,000" oninput="fmt(this);chk()"><span class="u">元</span></div>
      </div>

      <div class="field">
        <label class="lbl">月息幾分？<span class="opt">1 分 ＝ 每月 1%</span></label>
        <div class="chips" id="rateChips">
          <button class="chip" onclick="pickRate(this,2)">2 分</button>
          <button class="chip" onclick="pickRate(this,3)">3 分</button>
          <button class="chip" onclick="pickRate(this,4)">4 分</button>
          <button class="chip" onclick="pickRate(this,5)">5 分</button>
        </div>
        <div class="ni" style="margin-top:8px;"><input id="rate" inputmode="decimal" placeholder="其他，直接輸入" oninput="rateTyped();chk()"><span class="u">分</span></div>
      </div>

      <div class="field">
        <label class="lbl">目前繳到第幾期？<span class="opt">1 期＝1 個月</span></label>
        <div class="ni"><input id="period" inputmode="numeric" placeholder="例：24" oninput="digits(this);chk()"><span class="u">期</span></div>
      </div>

      <div class="field">
        <label class="lbl">其中有幾期沒繳？<span class="opt">沒有就填 0</span></label>
        <div class="ni"><input id="unpaid" inputmode="numeric" placeholder="例：0" oninput="digits(this);chk()"><span class="u">期</span></div>
      </div>

      <div class="nav">
        <button class="btn btn-back" onclick="go(1)">上一步</button>
        <button class="btn btn-go" id="g2" onclick="go(3)" disabled>下一步</button>
      </div>
    </div>

    <!-- STEP 3 -->
    <div class="step" id="s3">
      <div class="q"><span class="num">3</span>借款時被收了哪些費用？</div>
      <div class="q-sub">這些都會影響你「真正借到手」的金額。</div>

      <div class="field">
        <label class="lbl">先被扣了幾個月利息？<span class="opt">預扣利息</span></label>
        <div class="chips" id="prepayChips">
          <button class="chip" onclick="pickPrepay(this,0)">沒有</button>
          <button class="chip" onclick="pickPrepay(this,1)">1 個月</button>
          <button class="chip" onclick="pickPrepay(this,2)">2 個月</button>
          <button class="chip sel" onclick="pickPrepay(this,3)">3 個月</button>
          <button class="chip" onclick="pickPrepay(this,4)">4 個月</button>
          <button class="chip" onclick="pickPrepay(this,6)">6 個月</button>
        </div>
        <div class="hintline">借款時對方先扣掉的利息，你其實沒拿到這筆。</div>
      </div>

      <div class="field">
        <label class="lbl">開辦費及其他名目費用<span class="opt">沒有就填 0</span></label>
        <div class="ni"><input id="fees" inputmode="numeric" placeholder="例：120,000" oninput="fmt(this)"><span class="u">元</span></div>
        <div class="hintline">開辦費、手續費、服務費、代書費…等加總。</div>
      </div>

      <div class="nav">
        <button class="btn btn-back" onclick="go(2)">上一步</button>
        <button class="btn btn-go" onclick="calc()">看結果</button>
      </div>
    </div>

    <!-- STEP 4: RESULT -->
    <div class="step" id="s4">
      <div id="result"></div>

      <div class="legend">
        <div class="legend-t">顏色代表什麼？</div>
        <div class="leg-row"><div class="leg-dot g"></div><div><b>綠燈</b>　金主開的價，跟法律上合理的數字很接近（高出 15% 以內）。請求款項幾乎合於法律。</div></div>
        <div class="leg-row"><div class="leg-dot y"></div><div><b>黃燈</b>　金主開的價，明顯高過法律上合理的數字（高出 15~50%）。法律上有協調空間。</div></div>
        <div class="leg-row"><div class="leg-dot r"></div><div><b>紅燈</b>　金主開的價，遠高過法律上合理的數字（高出 50% 以上）。法律上有重大協調空間。</div></div>
      </div>

      <!-- CTA / lead -->
      <div class="cta-card" id="ctaCard">
        <h2>我們知道你的困難</h2>
        <p>留下稱呼與電話，我們提供貸款案件<b>免費法律諮詢</b>，幫你算清楚法律上實際該還多少、以及怎麼談。讓我們知道你需要我們。</p>
        <div class="lead-field"><input id="leadName" placeholder="怎麼稱呼您？" oninput="chkLead()"></div>
        <div class="lead-field"><input id="leadPhone" inputmode="tel" placeholder="聯絡電話" oninput="chkLead()"></div>
        <button class="btn-consult" id="consultBtn" onclick="submitLead()" disabled>我想諮詢律師</button>
        <div class="cta-fine">送出即表示同意我們以電話／LINE 與您聯繫。我們重視您的隱私。</div>
      </div>

      <div class="restart"><button onclick="restart()">↻ 重新試算</button></div>
    </div>

    <!-- STEP 5: THANKS -->
    <div class="step" id="s5">
      <div class="thanks">
        <div class="big">✅</div>
        <h2>已收到您的需求</h2>
        <p>我們的律師團隊會盡快與您聯繫。<br>也歡迎現在就加入官方 LINE，更快得到回覆。</p>
        <a id="lineLink" href="https://lin.ee/NhzfUVZ" target="_blank" rel="noopener">加入官方 LINE　→</a>
      </div>
    </div>

  </div>

  <div class="disclaimer">
    本試算為自動估算結果，僅供參考，<b>非正式法律意見</b>；實際金額需經律師依個案文件與法院見解判斷。
    依民法 §205（年利率上限 16%）、§323（清償抵充順序）等規定設計。
  </div>

</div>
  </main>

  <script is:inline>

// ───── state ─────
let rate = 0, prepay = 3;

// ───── input helpers ─────
function fmt(el){ const v=el.value.replace(/[^0-9]/g,''); el.value = v?parseInt(v,10).toLocaleString('zh-TW'):''; }
function digits(el){ el.value = el.value.replace(/[^0-9]/g,''); }
function num(id){ return parseFloat((document.getElementById(id).value||'').replace(/[^0-9.]/g,''))||0; }

function pickRate(btn,v){
  document.querySelectorAll('#rateChips .chip').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel'); rate=v; document.getElementById('rate').value=''; chk();
}
function rateTyped(){
  const v=parseFloat(document.getElementById('rate').value)||0;
  if(v>0){ document.querySelectorAll('#rateChips .chip').forEach(b=>b.classList.remove('sel')); rate=v; }
}
function pickPrepay(btn,v){
  document.querySelectorAll('#prepayChips .chip').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel'); prepay=v;
}

// ───── step nav ─────
function go(n){
  document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));
  document.getElementById('s'+n).classList.add('active');
  document.querySelectorAll('#dots .dot').forEach((d,i)=>d.classList.toggle('on', i < Math.min(n,4)));
  document.querySelector('.scroll').scrollTo({top:0});
  window.scrollTo({top:0,behavior:'smooth'});
}

// ───── enable-next checks ─────
function chk(){
  document.getElementById('g1').disabled = !(num('settle')>0);
  const ok2 = num('prin')>0 && rate>0 && num('period')>0 && document.getElementById('unpaid').value!=='';
  document.getElementById('g2').disabled = !ok2;
}
function chkLead(){
  const ok = document.getElementById('leadName').value.trim() && document.getElementById('leadPhone').value.trim().length>=8;
  document.getElementById('consultBtn').disabled = !ok;
}

// ───── calculation (數字不顯示，只決定顏色) ─────
function calc(){
  const settle = num('settle');
  const prin   = num('prin');
  const yuefen = rate;
  const period = num('period');
  const unpaid = num('unpaid');
  const fees   = num('fees');

  const monthly = prin * (yuefen/100);     // 只繳息：本金 × 月息
  const annual  = yuefen * 12;
  const legalR  = Math.min(annual, 16);
  const prepayAmt = prepay * monthly;
  const base = Math.max(0, prin - fees - prepayAmt);
  const paid = Math.max(0, period - unpaid);

  const r = legalR/100/12;
  let bal = base;
  for(let i=0;i<paid;i++){ const it=bal*r; let tp=monthly-it; if(tp<=0) continue; if(tp>=bal){bal=0;break;} bal-=tp; }
  const remaining = Math.max(0, bal);
  const arrears = remaining * 0.16 * (unpaid/12);
  const legalNow = remaining + arrears;

  let gap, band;
  if(legalNow<=0){ band='red'; }
  else { gap = (settle - legalNow)/legalNow; band = gap<=0.15 ? 'green' : gap<=0.5 ? 'yellow' : 'red'; }

  renderResult(band);
  go(4);
}

function renderResult(band){
  const data = {
    green:  { emoji:'🟢', badge:'綠燈', title:'幾乎合於法律', desc:'金主開的價，跟法律上合理的數字很接近。雖然空間有限，但仍建議讓律師確認有沒有可以爭取的細節。' },
    yellow: { emoji:'🟡', badge:'黃燈', title:'有協調空間', desc:'金主開的價，明顯高過法律上合理的數字。法律上你<b>有協調空間</b>，值得進一步評估怎麼談。' },
    red:    { emoji:'🔴', badge:'紅燈', title:'有重大協調空間', desc:'金主開的價，遠高過法律上合理的數字。這是<b>好消息</b>——代表你在法律上有<b>很大的施力空間</b>，很可能不必照他要求的金額還。' },
  }[band];
  document.getElementById('result').innerHTML = `
    <div class="result-card ${band}">
      <div class="r-emoji">${data.emoji}</div>
      <div class="r-badge">${data.badge}</div>
      <div class="r-title">${data.title}</div>
      <div class="r-desc">${data.desc}</div>
    </div>`;
}

// ───── lead submit ─────
function submitLead(){
  const payload = {
    name: document.getElementById('leadName').value.trim(),
    phone: document.getElementById('leadPhone').value.trim(),
    // 試算脈絡（可一併送給事務所，方便預先了解）
    settle: num('settle'), prin: num('prin'), rate: rate, period: num('period'), unpaid: num('unpaid'), prepay: prepay, fees: num('fees'),
    ts: new Date().toISOString()
  };

  // ⚠️ DEMO：此處為留資送出的「接點」。正式上線時，Kenny 在這裡接寄信端點
  //    （例如 Formspree / 自家 API），收件人：credit@pamolaw.com。
  //    範例：
  //    fetch('YOUR_FORM_ENDPOINT', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
  console.log('[lead payload → credit@pamolaw.com]', payload);

  go(5);
  // 進入感謝頁後，自動導去官方 LINE
  setTimeout(()=>{ window.location.href = 'https://lin.ee/NhzfUVZ'; }, 1800);
}

function restart(){
  document.querySelectorAll('input').forEach(i=>i.value='');
  rate=0; prepay=3;
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('sel'));
  document.querySelectorAll('#prepayChips .chip')[3].classList.add('sel');
  chk(); chkLead();
  go(1);
}


function setMoneyFromQuery(id, value){
  if(!value) return;
  const el = document.getElementById(id);
  if(!el) return;
  const cleaned = String(value).replace(/[^0-9]/g,'');
  el.value = cleaned ? parseInt(cleaned,10).toLocaleString('zh-TW') : '';
}
function applyLandingPrefill(){
  const params = new URLSearchParams(window.location.search);
  const debtTotal = params.get('debtTotal');
  setMoneyFromQuery('settle', debtTotal);
  setMoneyFromQuery('prin', debtTotal);
  chk();
}
applyLandingPrefill();

  </script>
</BaseLayout>
