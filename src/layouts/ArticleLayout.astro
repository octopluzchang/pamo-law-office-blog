---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  cover?: string;
}

const { title, description, cover } = Astro.props;
const coverImage = cover ?? '/assets/default_cover.png';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <div class="bg-[#f3f3f1] pointer-events-none fixed w-full h-full top-0 right-0 inset-0 z-20">
      <img src="/assets/article_bg.svg" alt="" class="w-full h-full object-cover" />
    </div>

    <div class="mx-auto max-w-3xl m-0 px-0 md:px-6 md:py-20 md:mt-20 relative z-30">
      <article class="overflow-hidden border border-[#d9d9d9] bg-white relative">
        <div class="aspect-square md:aspect-video bg-[#2a2a2a] relative">
          <div class="pointer-events-none absolute inset-0">
            <img src="/assets/hero_bg.svg" alt="" class="w-full h-full object-cover" />
          </div>
          <img
            src={coverImage}
            alt={title}
            class="relative z-10 h-full w-full object-cover"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        </div>

        <div class="px-6 py-10 md:px-12 md:py-14">
          <h1 class="text-3xl font-black leading-tight md:text-5xl text-center">
            {title}
          </h1>

          <slot name="share" />
          <slot />
        </div>
      </article>

      <slot name="after-content" />
    </div>
  </main>
</BaseLayout>